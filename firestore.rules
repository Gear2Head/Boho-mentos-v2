rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // GÜVENLİK KATI 1: GOD MODE (Süper Karargah)
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == "9z9OAxBXsFU3oPT8AqIxnDSfzNy2";
    }
    
    // GÜVENLİK KATI 2: KULLANICI PROFİLLERİ VE METADATALARI (Aranan Liste)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "9z9OAxBXsFU3oPT8AqIxnDSfzNy2");
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // GÜVENLİK KATI 3: KULLANICI ÖZEL VERİLERİ VE ELO PUANLARI (userData)
    match /userData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Sınavlar ve başarımlar
      match /{subcollections=**} {
         allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // GÜVENLİK KATI 4: YÖNETİCİ LOGLARI (Sadece Super Admin)
    match /adminLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == "9z9OAxBXsFU3oPT8AqIxnDSfzNy2";
    }
    
    // GÜVENLİK KATI 5: SİSTEM AYARLARI (Bakım Modu, Duyuru vb.)
    match /systemConfig/settings {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == "9z9OAxBXsFU3oPT8AqIxnDSfzNy2";
    }
    
    // SİSTEM META SAYAÇLARI
    match /system/{document=**} {
       allow read: if request.auth != null;
    }
  }
}

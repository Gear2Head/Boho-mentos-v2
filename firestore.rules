rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();

      match /logs/{logId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /exams/{examId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /failedQuestions/{questionId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /chatMessages/{messageId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /agendaEntries/{entryId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /focusSessions/{sessionId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /targets/{targetId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /system/{docId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      // [A5 FIX]: Eksik subcollection ownership rules eklendi
      match /directiveHistory/{recordId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /flashcards/{cardId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
      match /notifications/{notifId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isSuperAdmin();
      }
    }


    match /userData/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();

      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /adminLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }

    match /systemConfig/settings {
      allow read: if true; 
      allow write: if isSuperAdmin();
    }

    match /system/{document=**} {
       allow read: if isSignedIn();
       allow write: if isSuperAdmin();
    }
  }
}
